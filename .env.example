PORT=3001
GIT_ROOT=/Users/<you>/git
TTYD_URL=http://<your-host>.local:7681
REMOTE_CONTROL_URL=https://claude.ai/code
LOG_LEVEL=info

# Optional: prefix used in --remote-control identifiers (default: machine hostname).
# Set this explicitly if the hostname is long, ambiguous, or changes.
# REMOTE_CONTROL_PREFIX=MyMacMini

# Claude launch options
# CLAUDE_MODEL=claude-sonnet-4-6           # model passed to --model
# CLAUDE_EFFORT=medium                     # low | medium | high | highest
#
# WARNING: CLAUDE_SKIP_PERMISSIONS
# Setting this to true passes --dangerously-skip-permissions to every claude session.
# This disables ALL permission checks — claude can read, write, and delete any file
# accessible to your user account without asking. Only enable this if you fully
# understand and accept the risk. Never enable on a shared or multi-user machine.
# CLAUDE_SKIP_PERMISSIONS=false

# Optional: enable HTTP Basic auth as an extra credential layer.
# Leave both unset to rely on Cloudflare Access / network-level access control instead.
# BASIC_AUTH_USER=<you>
# BASIC_AUTH_PASS=<openssl rand -base64 32>
